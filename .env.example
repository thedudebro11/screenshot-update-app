# ── Target window ────────────────────────────────────────────────────────────
# Partial window title match (case-insensitive).
# Examples: "Chrome", "Notepad", "TeamViewer", "Remote Desktop"
# Run the app once and check logs/app.log for "Available windows:" if unsure.
TARGET_WINDOW_TITLE=Chrome

# ── Capture timing ────────────────────────────────────────────────────────────
# How often to take a screenshot, in minutes. Default: 10
CAPTURE_INTERVAL_MINUTES=10

# ── Web server ────────────────────────────────────────────────────────────────
# Local port for the web viewer. Access at http://localhost:PORT/?token=...
PORT=3456

# ── Auth ──────────────────────────────────────────────────────────────────────
# CHANGE THIS. Anyone with this token can see your screenshots.
# Make it something random, e.g. a UUID or a long random string.
AUTH_TOKEN=changeme-replace-this-now

# ── Paths (optional, defaults shown) ─────────────────────────────────────────
# SCREENSHOT_PATH=./screenshots/latest.png
# LOG_PATH=./logs/app.log
